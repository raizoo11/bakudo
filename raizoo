local function AutoTrainingLoop()
    local character = player.Character or player.CharacterAdded:Wait()
    local gym = workspace.Alive.NPCs.Gym
    if gym:IsA("Model") then
        character:PivotTo(gym:GetPivot())
    else
        character:PivotTo(gym.CFrame)
    end
    task.wait(1)

    while getgenv().AutoTraining do
        -- Cek hunger dulu, lalu fatigue
        checkAndHandleHunger(TrainButton, "Training ON", Color3.fromRGB(0,170,0))
        checkAndHandleFatigue(TrainButton, "Training ON", Color3.fromRGB(0,170,0))

        local success, err = pcall(function()
            character = player.Character or player.CharacterAdded:Wait()
            local machine = getMachine()
            if not machine then task.wait(3) return end

            if machine:IsA("Model") then
                character:PivotTo(machine:GetPivot())
            else
                character:PivotTo(machine.CFrame)
            end
            task.wait(1.5)

            fireproximityprompt(machine.Hold.ProximityPrompt)

            local minigame = player.PlayerGui:WaitForChild("Minigame")
            local choose = minigame:WaitForChild("Choose")
            task.wait(1.5)

            local staminaButton = choose.Holder.Stamina.Button
            for _,v in pairs(getconnections(staminaButton.Activated)) do v:Fire() end
            task.wait(1)

            local currentKey = minigame.KeyPress.Frame.CurrentKey
            local startTime = tick()

            while getgenv().AutoTraining and tick() - startTime < 57 do
                if getFatigue() > 80 then return end
                if getHunger() < 10 then return end  -- keluar loop minigame jika lapar
                local key = currentKey.Text
                if key and key ~= "" then
                    local enumKey = Enum.KeyCode[key:upper()]
                    if enumKey then
                        VirtualInputManager:SendKeyEvent(true, enumKey, false, game)
                        task.wait(0.05)
                        VirtualInputManager:SendKeyEvent(false, enumKey, false, game)
                    end
                end
                task.wait(0.1)
            end
        end)

        if not success then warn(err) end
        task.wait(1)
    end
end

