local function teleportHospital()
    local character = player.Character or player.CharacterAdded:Wait()
    local hospital = ReplicatedStorage:WaitForChild("TravelLocation"):WaitForChild("Hospital")
    if hospital:IsA("Model") then
        character:PivotTo(hospital:GetPivot())
    elseif hospital:IsA("BasePart") then
        character:PivotTo(hospital.CFrame)
    end
    task.wait(2)
end

local function findAvailableBed()
    local bedsFolder = workspace:WaitForChild("Interactables"):WaitForChild("Beds")
    for _, v in pairs(bedsFolder:GetChildren()) do
        if v.Name == "Hospital Bed" then
            local bedPos
            if v:IsA("Model") then
                bedPos = v:GetPivot().Position
            elseif v:IsA("BasePart") then
                bedPos = v.Position
            end
            if bedPos and not isOccupied(bedPos) then
                return v
            end
        end
    end
    return nil
end

local function handleFatigue()
    teleportHospital()

    local bed = findAvailableBed()
    if not bed then
        warn("Semua bed occupied! Teleport ulang...")
        teleportHospital()
        bed = findAvailableBed()
    end

    if not bed then
        warn("Tidak ada bed kosong, fallback ke bed terdekat...")
        local bedsFolder = workspace:WaitForChild("Interactables"):WaitForChild("Beds")
        for _, v in pairs(bedsFolder:GetChildren()) do
            if v.Name == "Hospital Bed" then
                bed = v
                break
            end
        end
    end

    if bed then
        local character = player.Character or player.CharacterAdded:Wait()
        if bed:IsA("Model") then
            character:PivotTo(bed:GetPivot())
        elseif bed:IsA("BasePart") then
            character:PivotTo(bed.CFrame)
        end
        task.wait(0.5)

        local main = bed:FindFirstChild("Main")
        if main then
            local prompt = main:FindFirstChild("ProximityPrompt")
            if prompt then
                fireproximityprompt(prompt)
            end
        end
    else
        warn("Hospital Bed tetap tidak ditemukan!")
    end

    repeat
        task.wait(5)
    until getFatigue() <= 1

    task.wait(2)
    pressSpace()
    task.wait(1)

    local character = player.Character or player.CharacterAdded:Wait()
    local gym = workspace.Alive.NPCs.Gym
    if gym:IsA("Model") then
        character:PivotTo(gym:GetPivot())
    else
        character:PivotTo(gym.CFrame)
    end
    task.wait(1)
end

-- HANDLE HUNGER: teleport ke Burger, beli & pakai Pizza sampai hunger >= 80
local function handleHunger()
    local character = player.Character or player.CharacterAdded:Wait()

    -- Teleport ke Burger NPC
    local burger = workspace:WaitForChild("Alive"):WaitForChild("NPCs"):WaitForChild("Burger")
    if burger and burger:FindFirstChild("HumanoidRootPart") then
        character:WaitForChild("HumanoidRootPart").CFrame = burger.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
        task.wait(0.3)
    end

    -- Loop beli & makan Pizza sampai hunger >= 80
    while getHunger() < 80 do
        -- Beli Pizza (qty 8 sekaligus)
        ReplicatedStorage:WaitForChild("Events"):WaitForChild("Server"):FireServer(
            "Misc", "DialogueShop", "Purchase",
            {
                {
                    ["Price"] = 54,
                    ["Quantity"] = 8,
                    ["Item"] = "Pizza"
                }
            }
        )
        task.wait(0.5)

        -- Equip Pizza dari Backpack
        local pizza = player.Backpack:FindFirstChild("Pizza") or character:FindFirstChild("Pizza")
        if pizza then
            pizza.Parent = character
            task.wait(0.2)
        end

        -- Use Pizza
        pizza = character:FindFirstChild("Pizza")
        if pizza then
            ReplicatedStorage:WaitForChild("Events"):WaitForChild("Server"):FireServer(
                "Misc", "Tool", "Activated", pizza
            )
        end

        task.wait(1)
    end

    task.wait(0.5)
end

local function handleFatigueWithButton(button, onText, onColor)
    button.Text = "Recovery..."
    button.BackgroundColor3 = Color3.fromRGB(200,150,0)
    handleFatigue()
    button.Text = onText
    button.BackgroundColor3 = onColor
end

-- Wrapper hunger dengan update button
local function handleHungerWithButton(button, onText, onColor)
    button.Text = "Eating..."
    button.BackgroundColor3 = Color3.fromRGB(200,100,0)
    handleHunger()
    button.Text = onText
    button.BackgroundColor3 = onColor
end

local function checkAndHandleFatigue(button, onText, onColor)
    if getFatigue() > 80 then
        task.wait(1)
        pressSpace()
        task.wait(1)
        handleFatigueWithButton(button, onText, onColor)
        return true
    end
    return false
end

-- Cek hunger < 10, jika iya handle hunger dulu
local function checkAndHandleHunger(button, onText, onColor)
    if getHunger() < 10 then
        handleHungerWithButton(button, onText, onColor)
        return true
    end
    return false
end

