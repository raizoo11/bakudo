local function isOccupied(pos)
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local otherChar = otherPlayer.Character
            if otherChar then
                local otherPos = otherChar:GetPivot().Position
                if (otherPos - pos).Magnitude < 10 then
                    return true
                end
            end
        end
    end
    return false
end

local function getMachine()
    for _, machine in pairs(workspace.Interactables.TrainingMachines:GetChildren()) do
        if machine.Name == "StationaryBike" then
            local machinePos
            if machine:IsA("Model") then
                machinePos = machine:GetPivot().Position
            elseif machine:IsA("BasePart") then
                machinePos = machine.Position
            end
            if machinePos and not isOccupied(machinePos) then
                return machine
            end
        end
    end
    warn("Semua StationaryBike occupied!")
    return nil
end

