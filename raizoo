local function AutoRoadwalkLoop()
    while getgenv().AutoRoadwalk do
        checkAndHandleHunger(RoadwalkButton, "Roadwalk ON", Color3.fromRGB(0,170,0))

        if getFatigue() > 80 then
            handleFatigueWithButton(RoadwalkButton, "Roadwalk ON", Color3.fromRGB(0,170,0))
        end

        local character = player.Character or player.CharacterAdded:Wait()
        local gym = workspace.Alive.NPCs.Gym
        if gym:IsA("Model") then
            character:PivotTo(gym:GetPivot())
        else
            character:PivotTo(gym.CFrame)
        end
        task.wait(2)

        local buyArgs = {
            [1] = "Misc",
            [2] = "DialogueShop",
            [3] = "Purchase",
            [4] = {
                [1] = {
                    ["Price"] = 135,
                    ["Quantity"] = 1,
                    ["Item"] = "Roadwork"
                }
            }
        }
        ReplicatedStorage:WaitForChild("Events"):WaitForChild("Server"):FireServer(unpack(buyArgs))
        task.wait(2)

        local startArgs = {
            [1] = "Misc",
            [2] = "Roadwork",
            [3] = "Start"
        }
        ReplicatedStorage:WaitForChild("Events"):WaitForChild("Server"):FireServer(unpack(startArgs))
        task.wait(2)

        while getgenv().AutoRoadwalk do
            if getFatigue() > 80 then
                handleFatigueWithButton(RoadwalkButton, "Roadwalk ON", Color3.fromRGB(0,170,0))
                break
            end

            if getHunger() < 10 then
                handleHungerWithButton(RoadwalkButton, "Roadwalk ON", Color3.fromRGB(0,170,0))
                break  -- restart loop agar beli roadwork ulang
            end

            local checkpoint = workspace.Map:FindFirstChild("Roadwork") and
                workspace.Map.Roadwork:FindFirstChild("Checkpoint_1612702060")

            if checkpoint then
                character = player.Character or player.CharacterAdded:Wait()
                if checkpoint:IsA("Model") then
                    character:PivotTo(checkpoint:GetPivot())
                elseif checkpoint:IsA("BasePart") then
                    character:PivotTo(checkpoint.CFrame)
                end
                task.wait(1)
            else
                break
            end
        end
        task.wait(1)
    end
end

--------------------------------------------------
-- NOCLIP
--------------------------------------------------

local NoclipConnection
local NoclipEnabled = false

local function EnableNoclip()
    NoclipEnabled = true
    NoclipConnection = RunService.Stepped:Connect(function()
        local character = player.Character
        if character then
            for _,v in pairs(character:GetDescendants()) do
                if v:IsA("BasePart") then
                    v.CanCollide = false
                end
            end
        end
    end)
end

local function DisableNoclip()
    NoclipEnabled = false
    if NoclipConnection then
        NoclipConnection:Disconnect()
        NoclipConnection = nil
    end
end

