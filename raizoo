local function cancelQuest()
    pcall(function()
        firesignal(player.PlayerGui.Quest.Box.Cancel.MouseButton1Click)
    end)
end

local function AutoLostDogeLoop()
    local character = player.Character or player.CharacterAdded:Wait()
    local police = workspace.Alive.NPCs.Police
    if police:IsA("Model") then
        character:PivotTo(police:GetPivot())
    else
        character:PivotTo(police.CFrame)
    end
    task.wait(0.5)

    while getgenv().AutoLostDoge do
        local jobName = getJobName()
        if not jobName or jobName.Text ~= "Lost Doge" then
            if jobName then
                cancelQuest()
                task.wait(0.5)
            end
            character = player.Character or player.CharacterAdded:Wait()
            character:PivotTo(workspace.Map.Markers.Jobboard2.CFrame)
            task.wait(0.5)
            fireproximityprompt(workspace.Interactables.JobBoards.JB2.awfdawdaw.ProximityPrompt)
            task.wait(1)
        else
            character = player.Character or player.CharacterAdded:Wait()
            if workspace.Map:FindFirstChild("Doge") then
                local doge = workspace.Map.Doge
                if doge:IsA("Model") then
                    character:PivotTo(doge:GetPivot())
                else
                    character:PivotTo(doge.CFrame)
                end
            end
            task.wait(1)
        end
    end
end

