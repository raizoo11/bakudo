-- CEK FATIGUE
local function getFatigue()
    local ok, result = pcall(function()
        local characterData = ReplicatedStorage:WaitForChild("CharacterData", 5)
        if not characterData then return 0 end
        local playerData = characterData:WaitForChild(player.Name, 5)
        if not playerData then return 0 end
        local data = playerData:WaitForChild("Data", 5)
        if not data then return 0 end
        local fatigue = data:WaitForChild("Fatigue", 5)
        if not fatigue then return 0 end
        return fatigue.Value
    end)
    if ok then return result else return 0 end
end

-- CEK HUNGER (sama polanya seperti getFatigue)
local function getHunger()
    local ok, result = pcall(function()
        local characterData = ReplicatedStorage:WaitForChild("CharacterData", 5)
        if not characterData then return 100 end
        local playerData = characterData:WaitForChild(player.Name, 5)
        if not playerData then return 100 end
        local data = playerData:WaitForChild("Data", 5)
        if not data then return 100 end
        local hunger = data:WaitForChild("Hunger", 5)
        if not hunger then return 100 end
        return hunger.Value
    end)
    if ok then return result else return 100 end
end

